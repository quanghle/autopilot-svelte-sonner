{
	"name": "autopilot-svelte-sonner",
	"description": "An opinionated toast component for Svelte.",
	"license": "MIT",
	"author": "Robert Soriano <sorianorobertc@gmail.com>",
	"homepage": "https://quanghle.github.io/autopilot-svelte-sonner",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/quanghle/autopilot-svelte-sonner.git"
	},
	"bugs": "https://github.com/quanghle/autopilot-svelte-sonner/issues",
	"keywords": [
		"svelte",
		"toast"
	],
	"version": "1.1.0",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && pnpm run package",
		"preview": "vite preview",
		"package": "svelte-kit sync && svelte-package && publint",
		"test": "playwright test",
		"test:unit": "vitest",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"format": "prettier --write ."
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"dependencies": {
		"runed": "^0.37.1"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@testing-library/user-event": "^14.6.1",
		"@types/jest-axe": "^3.5.9",
		"copy-to-clipboard": "^3.3.3",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.16.0",
		"globals": "^17.4.0",
		"highlight.js": "^11.11.1",
		"jsdom": "^29.0.1",
		"mode-watcher": "^1.1.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"publint": "^0.3.18",
		"svelte": "^5.55.0",
		"svelte-check": "^4.4.5",
		"svelte-preprocess": "^6.0.3",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.2",
		"vite": "^8.0.2",
		"vitest": "^4.1.1"
	},
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"pnpm": {
		"onlyBuiltDependencies": [
			"@sveltejs/kit",
			"esbuild",
			"svelte-preprocess"
		]
	},
	"sideEffects": false,
	"packageManager": "pnpm@10.20.0"
}
